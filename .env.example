# Variables de entorno para AutorderBack

# ========================================
# BASE DE DATOS (PostgreSQL)
# ========================================
DB_USER=postgres
DB_HOST=localhost
DB_NAME=autorder_db
DB_PASSWORD=tu_password_aqui
DB_PORT=5432

# ========================================
# SEGURIDAD
# ========================================
SECRET=tu_clave_jwt_muy_larga_y_segura_cambiar_en_produccion_2024

